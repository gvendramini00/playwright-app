# Copy this file to .env and fill in the values.
# .env is git-ignored and must never be committed.

# ── Alira Back Office ────────────────────────────────────────────────────────
ALIRA_USERNAME=your_alira_user
ALIRA_PASSWORD=your_alira_password
# Optional — defaults to dev URLs if not set
# ALIRA_LOGIN_URL=https://gms.dev.tecnalis.com/alira-server/login.jsp
# ALIRA_BASE_URL=https://gms.dev.tecnalis.com/alira-server/

# ── Casino Gran Madrid (CGM) database ────────────────────────────────────────
CGM_DB_USERNAME=your_cgm_db_user
CGM_DB_PASSWORD=your_cgm_db_password
# Optional — defaults to dev DB if not set
# CGM_DB_URL=jdbc:mysql://192.168.16.56:3306/OGP?useSSL=false&serverTimezone=UTC

# ── Golden Park Portugal (GP-PT) database ────────────────────────────────────
GPPT_DB_USERNAME=your_gppt_db_user
GPPT_DB_PASSWORD=your_gppt_db_password
# Optional — defaults to dev DB if not set
# GPPT_DB_URL=jdbc:mysql://192.168.16.21:3306/OGP?useSSL=false&serverTimezone=UTC

# ── Playwright ───────────────────────────────────────────────────────────────
# Set to false only for local debugging — must be true in CI
# PLAYWRIGHT_HEADLESS=true
